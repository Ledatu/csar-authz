# syntax=docker/dockerfile:1
# Build context: parent directory (_csar/) for replace directive resolution.
FROM golang:1.25-alpine AS builder

WORKDIR /src

COPY csar-core/ ./csar-core/
COPY csar-proto/ ./csar-proto/

COPY csar-authz/go.mod csar-authz/go.sum ./csar-authz/
WORKDIR /src/csar-authz
RUN go mod download

WORKDIR /src
COPY csar-authz/ ./csar-authz/
WORKDIR /src/csar-authz
RUN CGO_ENABLED=0 go build -ldflags "-s -w" -o /csar-authz ./cmd/csar-authz

# ---
FROM alpine:3.21
RUN apk add --no-cache ca-certificates
RUN adduser -D -u 10001 csar
COPY --from=builder /csar-authz /usr/local/bin/csar-authz
USER csar
ENTRYPOINT ["csar-authz"]
